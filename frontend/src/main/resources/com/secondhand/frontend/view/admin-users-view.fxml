<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.secondhand.frontend.controller.AdminUsersController">
    <top>
        <VBox spacing="12.0">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Admin Dashboard &amp; User Management"/>

            <!-- نوار نمایش آمار سیستم -->
            <HBox spacing="12.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f4f4f4; -fx-padding: 10px; -fx-background-radius: 6px; -fx-border-color: #dddddd; -fx-border-radius: 6px;">
                <Label fx:id="totalUsersLabel" text="Total Users: -" style="-fx-font-weight: bold;"/>
                <Label text="|" style="-fx-text-fill: #aaa;"/>
                <Label fx:id="activeUsersLabel" text="Active: -" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
                <Label text="|" style="-fx-text-fill: #aaa;"/>
                <Label fx:id="blockedUsersLabel" text="Blocked: -" style="-fx-text-fill: red; -fx-font-weight: bold;"/>
                <Label text="|" style="-fx-text-fill: #aaa;"/>
                <Label fx:id="totalConversationsLabel" text="Chats: -" style="-fx-font-weight: bold;"/>
                <Label text="|" style="-fx-text-fill: #aaa;"/>
                <Label fx:id="totalRatingsLabel" text="Ratings: -" style="-fx-font-weight: bold;"/>
            </HBox>

            <HBox spacing="8.0">
                <Button onAction="#handleRefresh" text="Refresh"/>
                <Button onAction="#handleBack" text="Back"/>
            </HBox>
            <Label fx:id="errorLabel" style="-fx-text-fill: red;" visible="false" wrapText="true"/>
        </VBox>
    </top>
    <center>
        <ListView fx:id="usersListView" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0"/>
            </BorderPane.margin>
        </ListView>
    </center>
</BorderPane>
