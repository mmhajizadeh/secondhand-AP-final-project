<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.NewAdController">
    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2C3E50; -fx-padding: 0 20 0 20;">
            <Label text="Post a New Advertisement" textFill="WHITE">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
        </HBox>
    </top>

    <!-- Form Area -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #ECF0F1; -fx-padding: 40;">
            <VBox maxWidth="500.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

                <VBox spacing="5.0">
                    <Label text="Title:" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
                    <TextField fx:id="titleField" promptText="Enter ad title..." prefHeight="35.0" />
                </VBox>

                <HBox spacing="20.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Price (Tomans):" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
                        <TextField fx:id="priceField" promptText="e.g., 500000" prefHeight="35.0" />
                    </VBox>
                </HBox>

                <HBox spacing="20.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Category:" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
                        <ComboBox fx:id="categoryComboBox" maxWidth="1.7976931348623157E308" prefHeight="35.0" promptText="Select Category" />
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="City:" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
                        <ComboBox fx:id="cityComboBox" maxWidth="1.7976931348623157E308" prefHeight="35.0" promptText="Select City" />
                    </VBox>
                </HBox>

                <VBox spacing="5.0">
                    <Label text="Description:" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
                    <TextArea fx:id="descriptionArea" prefHeight="120.0" promptText="Describe your item..." wrapText="true" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Images (Max 3):" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Button mnemonicParsing="false" onAction="#handleSelectImages" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-cursor: hand;" text="Browse Images..." />
                        <Label fx:id="imageCountLabel" text="0/3 selected" textFill="#7f8c8d" />
                    </HBox>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-cursor: hand;" text="Cancel" />
                    <Button mnemonicParsing="false" onAction="#handleSubmit" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Submit Ad" />
                </HBox>

            </VBox>
        </VBox>
    </center>
</BorderPane>