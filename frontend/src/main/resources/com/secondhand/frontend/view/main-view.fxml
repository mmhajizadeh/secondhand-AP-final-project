<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.MainController">

   <!-- 1. Header Area (Top) -->
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="950.0" style="-fx-background-color: #2C3E50; -fx-padding: 0 20 0 20;" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="userInfoLabel" styleClass="header-label" text="Guest User" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="15.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Button fx:id="adminDashboardBtn" mnemonicParsing="false" onAction="#onAdminDashboardAction" style="-fx-background-color: #E67E22; -fx-text-fill: white; -fx-cursor: hand;" text="Admin Dashboard" visible="false" />
                  <Button fx:id="authBtn" mnemonicParsing="false" onAction="#onAuthAction" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-cursor: hand;" text="Login / Register" />
               </children>
            </HBox>
         </children>
      </HBox>
   </top>

   <!-- 2. Sidebar Navigation (Left) -->
   <left>
      <VBox prefWidth="180.0" spacing="10.0" style="-fx-background-color: #34495E; -fx-padding: 20 10 20 10;" BorderPane.alignment="CENTER">
         <children>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onAdsNavAction" style="-fx-background-color: #1ABC9C; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="📢 All Ads" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onNewAdNavAction" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="➕ New Ad" />
            <Button layoutX="20.0" layoutY="66.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onMyAdsNavAction" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="📣 My Ads" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onFavoritesNavAction" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="❤ Favorites" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onConversationsNavAction" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="💬 Conversations" />
         </children>
      </VBox>
   </left>

   <!-- 3. Center Area (Search + Ads Grid) -->
   <center>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <!-- Search & Filters Container -->
            <VBox spacing="10.0" style="-fx-background-color: #ECF0F1; -fx-background-radius: 8;">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <TextField fx:id="searchField" promptText="Search items..." HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="categoryComboBox" prefWidth="130.0" promptText="Category" />
                        <ComboBox fx:id="cityComboBox" prefWidth="130.0" promptText="City" />
                        <Button mnemonicParsing="false" onAction="#onSearchAction" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-cursor: hand;" text="Search" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <TextField fx:id="minPriceField" prefWidth="120.0" promptText="Min Price" />
                        <TextField fx:id="maxPriceField" prefWidth="120.0" promptText="Max Price" />
                        <Button mnemonicParsing="false" onAction="#onClearFiltersAction" style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-cursor: hand;" text="Clear Filters" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
               </padding>
            </VBox>

            <!-- Ads Grid ScrollPane -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="adsContainer" hgap="15.0" vgap="15.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
