<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.StartConversationController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Start a Conversation"/>

    <Label fx:id="targetInfoLabel" style="-fx-font-size: 13px; -fx-text-fill: #444444; -fx-font-weight: bold;" text="To: -"/>

    <VBox spacing="4.0">
        <Label text="Message"/>
        <TextArea fx:id="messageField" prefRowCount="3" wrapText="true"/>
    </VBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;" visible="false" wrapText="true"/>

    <Button fx:id="sendButton" defaultButton="true" maxWidth="Infinity" onAction="#handleSend" text="Send"/>
</VBox>
