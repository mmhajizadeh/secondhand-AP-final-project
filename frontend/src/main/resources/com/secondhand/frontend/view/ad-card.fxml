<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" nodeOrientation="RIGHT_TO_LEFT" prefHeight="150.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 4); -fx-cursor: hand;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.AdCardController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <StackPane prefHeight="120.0" prefWidth="120.0" style="-fx-background-color: #ECF0F1; -fx-background-radius: 6; -fx-border-color: #BDC3C7; -fx-border-radius: 6;">
         <children>
            <ImageView fx:id="adImage" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </StackPane>

      <VBox prefHeight="130.0" prefWidth="255.0" spacing="8.0" HBox.hgrow="ALWAYS">
         <children>
            <Label fx:id="titleLabel" nodeOrientation="RIGHT_TO_LEFT" text="عنوان آگهی" textAlignment="RIGHT">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <Label fx:id="priceLabel" nodeOrientation="RIGHT_TO_LEFT" text="500,000 تومان" textAlignment="RIGHT">
               <font>
                  <Font size="13.0" />
               </font>
            </Label>
            <Label fx:id="locationTimeLabel" nodeOrientation="RIGHT_TO_LEFT" text="تهران | لحظاتی پیش" textAlignment="RIGHT" textFill="#888888">
               <font>
                  <Font size="11.0" />
               </font>
            </Label>
            <Button fx:id="favoriteButton" mnemonicParsing="false" onAction="#handleFavoriteClick" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 14px;" text="♡" textAlignment="CENTER" />
         </children>
      </VBox>
   </children>
</HBox>