<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.secondhand.frontend.controller.RegisterController">
    <VBox alignment="CENTER" spacing="10.0">
        <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
        </padding>

        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Register"/>

        <VBox spacing="4.0">
            <Label text="Username"/>
            <TextField fx:id="usernameField" promptText="e.g. ali_reza"/>
        </VBox>

        <VBox spacing="4.0">
            <Label text="Full Name"/>
            <TextField fx:id="fullNameField" promptText="Your full name"/>
        </VBox>

        <VBox spacing="4.0">
            <Label text="Phone Number"/>
            <TextField fx:id="phoneField" promptText="09xxxxxxxxx"/>
        </VBox>

        <VBox spacing="4.0">
            <Label text="Email (optional)"/>
            <TextField fx:id="emailField" promptText="example@mail.com"/>
        </VBox>

        <VBox spacing="4.0">
            <Label text="Password"/>
            <PasswordField fx:id="passwordField" promptText="At least 6 characters"/>
        </VBox>

        <Label fx:id="errorLabel" style="-fx-text-fill: red;" visible="false" wrapText="true"/>

        <Button fx:id="registerButton" defaultButton="true" maxWidth="Infinity" onAction="#handleRegister" text="Register"/>

        <Hyperlink onAction="#goToLogin" text="Already have an account? Login"/>
    </VBox>
</ScrollPane>
