<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.LoginController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
    </padding>

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Login"/>

    <VBox spacing="4.0">
        <Label text="Username"/>
        <TextField fx:id="usernameField" promptText="Enter your username"/>
    </VBox>

    <VBox spacing="4.0">
        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="Enter your password"/>
    </VBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;" visible="false" wrapText="true"/>

    <Button fx:id="loginButton" defaultButton="true" maxWidth="Infinity" onAction="#handleLogin" text="Login"/>

    <Hyperlink onAction="#handleGuestLogin" text="Continue as Guest"/>

    <Hyperlink onAction="#goToRegister" text="Don't have an account? Register"/>
</VBox>